# =============================================================================
# Post Service Agent environment example
# =============================================================================

# local: run Django + post_ai in this project.
# microservice: keep Django as web/API shell and call external AI/SFT services.
POST_SERVICE_MODE=local

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=dev-only-post-service-agent
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
STATIC_VERSION=20260623

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
# Default runtime database is PostgreSQL. SQLite is only for explicit test
# overrides, not the normal application path.
DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_DB_NAME=post_service_agent
DJANGO_DB_USER=post_service
DJANGO_DB_PASSWORD=post_service
DJANGO_DB_HOST=127.0.0.1
DJANGO_DB_PORT=5432

# Used by post_ai pgvector provider. Leave empty to let code build it from the
# DJANGO_DB_* values.
POST_AI_PGVECTOR_DSN=

# -----------------------------------------------------------------------------
# Vector store
# -----------------------------------------------------------------------------
# Switchable providers: pgvector, faiss.
POST_AI_VECTOR_PROVIDER=pgvector
POST_AI_PGVECTOR_TABLE=core_postalembedding
POST_AI_FAISS_ARTIFACT_DIR=artifacts/faiss

# -----------------------------------------------------------------------------
# Model providers
# -----------------------------------------------------------------------------
POST_AI_CHAT_PROVIDER=ollama
POST_AI_CHAT_MODEL=gpt-oss:20b
POST_AI_EMBEDDING_PROVIDER=ollama
POST_AI_EMBEDDING_MODEL=qwen3-embedding:8b
OLLAMA_BASE_URL=http://localhost:11434

# Optional providers.
VLLM_BASE_URL=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
SFT_PROVIDER=
SFT_MODEL=
SFT_FASTAPI_BASE_URL=

# -----------------------------------------------------------------------------
# Local development switches
# -----------------------------------------------------------------------------
# 1 skips real chat model generation for UI/API tests.
POST_SERVICE_FAKE_LLM=0
